# ── .dockerignore ─────────────────────────────────────────────────────────────
# Shared by both engine and frontend builds.
# Copy this file to the repo root of each service.

# Version control
.git
.gitignore
.gitattributes

# Docs and config not needed in image
README*
LICENSE*
*.md
.editorconfig
.env*

# Rust — build artifacts (keep Cargo.toml/lock for layer caching)
target/

# Node — only exclude what's safe to exclude
# (node_modules is rebuilt inside the image via npm ci)
node_modules/
.svelte-kit/
build/

# Test artifacts
coverage/
*.test.*
*.spec.*

# CI
.github/
.gitea/

# IDE
.vscode/
.idea/
*.swp
*.swo
